# Supabase project metadata for @supabase/server. Copy these from the Supabase dashboard Connect dialog.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_<replace-me>"
# Never commit a real secret key.
SUPABASE_SECRET_KEY="sb_secret_<replace-me>"
SUPABASE_JWKS_URL="https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json"

# Application runtime connection for the shared Supabase Cloud development database.
DATABASE_URL="postgresql://app:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
# Direct connection for Prisma migrate and other administrative commands.
DIRECT_URL="postgresql://prisma:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
# Disposable database used only by npm test. The database name must clearly include test.
TEST_DATABASE_URL="postgresql://test_app:<password>@db.example.com:5432/app_test?sslmode=require"
# Direct connection for Prisma reset during tests. Falls back to TEST_DATABASE_URL when omitted.
TEST_DIRECT_URL="postgresql://test_admin:<password>@db.example.com:5432/app_test?sslmode=require"
PORT=3000
CORS_ORIGIN=http://localhost:5173
BACKEND_API_TOKEN="<shared-token-with-frontend>"
DEEZER_API_BASE_URL=https://api.deezer.com
DEEZER_PREVIEW_CACHE_TTL_SECONDS=21600
DEEZER_REQUEST_TIMEOUT_MS=5000
DEEZER_SEARCH_LIMIT=5
MAX_JSON_BODY_BYTES=16384
SETLIST_CREATE_RATE_LIMIT_MAX=20
SETLIST_CREATE_RATE_LIMIT_WINDOW_MS=60000
PREVIEW_REFRESH_RATE_LIMIT_MAX=20
PREVIEW_REFRESH_RATE_LIMIT_WINDOW_MS=60000
